#!/usr/bin/env python3
import subprocess
import sys
from pathlib import Path

repo_root = Path(__file__).resolve().parent.parent
# Walk up from repo_root until we find a .venv directory
search = repo_root
while search != search.parent:
    candidate = search / ".venv" / "bin" / "python3"
    if candidate.exists():
        flow_venv = candidate
        break
    search = search.parent
else:
    flow_venv = repo_root.parent.parent / ".venv" / "bin" / "python3"

result = subprocess.run(
    [str(flow_venv), "-m", "pytest", "tests/", "-v", "--rootdir", str(repo_root)],
    cwd=str(repo_root),
)
sys.exit(result.returncode)
